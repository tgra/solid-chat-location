@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix chat: <http://example.org/ns/chat#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix mee: <http://www.w3.org/ns/pim/meeting#> .

###############################################################################
# Example Chat Channel
###############################################################################

chat:chatChannel1
    a mee:LongChat ;

    prov:hasLocation [
        # Template defining dynamic storage path
        chat:locationTemplate "/chat/{yyyy}/{mm}/{dd}/" ;

        # Exactly three variables
        chat:locationVariable "yyyy" ,
                              "mm" ,
                              "dd" ;

        # Binding for year
        chat:locationBinding [
            chat:variable "yyyy" ;
            prov:wasDerivedFrom dc:created ;
        ] ;

        # Binding for month
        chat:locationBinding [
            chat:variable "mm" ;
            prov:wasDerivedFrom dc:created ;
        ] ;

        # Binding for day
        chat:locationBinding [
            chat:variable "dd" ;
            prov:wasDerivedFrom dc:created ;
        ] ;

        # Optional resolved URI (must be IRI per shape)
        chat:resolvedURI <https://example.org/chat/2026/04/10/> ;
    ] .