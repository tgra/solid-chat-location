@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix chat: <http://example.org/ns/chat#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mee: <http://www.w3.org/ns/pim/meeting#> .
@prefix chat_shape: <https://solidproject.org/shapes/chat#> .

################################################################################
# Node Shape for ChatChannel
################################################################################

chat_shape:ChatChannelShape
    a sh:NodeShape ;
    sh:targetClass mee:LongChat ;  # applies to LongChat instances
    sh:name "Chat Channel Shape" ;
    sh:description "Shape for chat channels with dynamic location templates." ;
    sh:property chat_shape:ChatChannelLocationShape .

################################################################################
# Property Shape for ChatChannel Location
################################################################################

chat_shape:ChatChannelLocationShape
    a sh:PropertyShape ;
    sh:path prov:hasLocation ;  # property of the node shape
    sh:minCount 1 ; # allow multiple location descriptions for multiple days
    sh:codeIdentifier "chatChannelLocation" ;
    sh:name "Chat Channel Location Shape" ;
    sh:description "Defines a URI template, variable mappings, and optional resolved URI for chat storage." ;
    sh:nodeKind sh:BlankNodeOrIRI ;

    # Template property
    sh:property [
        sh:path chat:locationTemplate ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:description "URI template string for dynamic chat storage paths." ;
    ] ;

    # Variables property
    sh:property [
        sh:path chat:locationVariable ;
        sh:minCount 3 ;
        sh:maxCount 3 ;
        sh:description "List of variables used in the template (e.g., yyyy, mm, dd)." ;
        sh:in ("yyyy" "mm" "dd") ;
    ] ;

    # Bindings property
    sh:property [
    sh:path chat:locationBinding ;
    sh:minCount 3 ;
    sh:node [
        sh:property [
            sh:path chat:variable ;
            sh:datatype xsd:string ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
            sh:in ("yyyy" "mm" "dd") ;
        ] ;
        sh:property [
            sh:path prov:wasDerivedFrom ;
            sh:nodeKind sh:IRI ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
        ] ;
    ] ;
] ;

    # Optional resolved URI property
    sh:property [
        sh:path chat:resolvedURI ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
        sh:description "Optional fully resolved URI for clients that do not support templates." ;
    ] .

