@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix ex: <https://example.org/data/> .
@prefix chat_shape: <https://solidproject.org/shapes/chat#> .
@prefix mee: <http://www.w3.org/ns/pim/meeting#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#############################
# ChatChannel Node Shape
#############################
ex:ChatChannelShape
    a sh:NodeShape ;
    sh:targetClass mee:LongChat ;
    sh:property [
        sh:path prov:hasLocation ;
        sh:minCount 1 ;           # must have at least one location
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:property [
            sh:path prov:hasLocation ;
            sh:nodeKind sh:IRI ;
            sh:minCount 1 ;
        ] ;
        sh:property [
            sh:path chat_shape:year ;
            sh:datatype xsd:gYear ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
        ] ;
        sh:property [
            sh:path chat_shape:month ;
            sh:datatype xsd:gMonth ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
        ] ;
        sh:property [
            sh:path chat_shape:day ;
            sh:datatype xsd:gDay ;
            sh:minCount 1 ;
            sh:maxCount 1 ;
        ] ;
    ] .