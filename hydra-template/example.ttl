@prefix ex: <https://example.org/data/> .
@prefix chat_shape: <https://solidproject.org/shapes/chat#> .
@prefix mee: <http://www.w3.org/ns/pim/meeting#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix hydra: <http://www.w3.org/ns/hydra/core#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#############################
# Chat Channel
#############################

ex:chat1
    a mee:LongChat ;
    dc:title "Project Chat" ;
    dc:created "2026-04-07T12:00:00Z"^^xsd:dateTime ;

    # Link to Hydra-based location description
    prov:hasLocation ex:chat1-location .

#############################
# Location Node (Hydra Template)
#############################

ex:chat1-location
    hydra:template "/chat/{year}/{month}/{day}/" ;

    hydra:mapping ex:mapYear,
                  ex:mapMonth,
                  ex:mapDay .

#############################
# Variable Mappings
#############################

ex:mapYear
    hydra:variable "year" ;
    prov:wasDerivedFrom dc:created .

ex:mapMonth
    hydra:variable "month" ;
    prov:wasDerivedFrom dc:created .

ex:mapDay
    hydra:variable "day" ;
    prov:wasDerivedFrom dc:created .